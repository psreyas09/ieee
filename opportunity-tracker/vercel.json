{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "^/([^.]+)$",
            "dest": "/frontend/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/$1"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/scrape-batch",
            "schedule": "0 1 * * *"
        }
    ]
}