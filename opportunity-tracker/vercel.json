{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "backend/api/**/*.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/api/$1"
        },
        {
            "src": "/(.*\\.[a-zA-Z0-9]+)$",
            "dest": "/frontend/dist/$1"
        },
        {
            "src": "/([^.]*)",
            "dest": "/frontend/dist/index.html"
        }
    ]
}